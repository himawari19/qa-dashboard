# ============================================================
# Copy file ini menjadi .env dan isi nilainya
# ============================================================

# Production: Neon/Postgres
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"
RESET_SECRET="use-a-random-string"

# Local development:
# Leave DATABASE_URL empty to use SQLite automatically.

# Auth
AUTH_SECRET="use-a-long-random-string"
