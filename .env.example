# ============================================================
# Copy file ini menjadi .env dan isi nilainya
# ============================================================

# Production: Neon/Postgres
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Local development:
# Leave DATABASE_URL empty to use SQLite automatically.

# Auth
# AUTH_USERNAME="admin"
# AUTH_PASSWORD="change-me"
# AUTH_SECRET="use-a-long-random-string"
