{
  "name": "qa-daily",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "test": "vitest run",
    "precheck": "pnpm lint && npx tsc --noEmit && next build",
    "ci:check": "pnpm test && pnpm precheck",
    "test:watch": "vitest",
    "start": "next start",
    "lint": "eslint .",
    "db:init": "tsx prisma/init-db.ts",
    "db:migrate:test-structure": "tsx scripts/migrate-test-structure.ts",
    "db:compact:test-ids": "tsx scripts/compact-test-ids.ts",
    "db:seed": "tsx scripts/seed-saucedemo.ts",
    "db:seed:local": "node seed.mjs",
    "db:backup": "node scripts/backup-db.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@phosphor-icons/react": "^2.1.10",
    "@types/pdfkit": "^0.17.6",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "next": "16.2.6",
    "pdfkit": "^0.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "fast-check": "^4.8.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
